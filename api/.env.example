# Copy to .env for local development.
# In Railway, set these via the service Variables tab.
# Use Railway's reference syntax for DATABASE_URL and REDIS_URL:
#   DATABASE_URL=${{ Postgres.DATABASE_URL }}
#   REDIS_URL=${{ Redis.REDIS_URL }}

NODE_ENV=development
PORT=3000

DATABASE_URL=postgres://postgres:postgres@localhost:5432/meetingcheck
# Set DATABASE_SSL=disable for local Postgres without certs. Railway's internal
# network uses self-signed certs; leave unset in production.
DATABASE_SSL=disable

REDIS_URL=redis://localhost:6379

# 32+ character random string. Hashes IPs before storage so we can rate-limit
# and dedupe without keeping PII. Rotate quarterly.
# Generate: openssl rand -hex 32
IP_SALT=dev-only-change-me

# Cloudflare Turnstile secret. Leave blank in dev; verifyTurnstile() no-ops.
TURNSTILE_SECRET_KEY=

# Bearer token for POST /admin/review. Leave blank in dev to disable the route.
# Generate: openssl rand -hex 32
ADMIN_TOKEN=

# Frontend origin allowed by CORS. Extension origins always allowed.
ALLOWED_ORIGIN=http://localhost:5173
